# ─── Campus Co-Pilot frontend env ────────────────────────────────────────────
#
# 1. Copy this file to `.env.local` (gitignored via *.local)
# 2. Fill in the values below
# 3. `vercel dev` (boots the Vite app + /api serverless functions together)
#    — or `npm run dev` if you only need the UI without the chat backend
#
# Two flavors of vars:
#   • Unprefixed  → server-only. Read by the /api serverless functions via
#                   process.env. Never bundled into the browser.
#   • VITE_*      → browser-bundled at build time. Anything here is visible
#                   in the built JS to anyone who views source.
#
# For production (Vercel): add the same variables under
# Vercel Project → Settings → Environment Variables. Unprefixed ones go to
# Server; VITE_* ones to Preview/Production/Development.

# ─── Bedrock (server-side, required for /api/chat) ───────────────────────────
# Short-term keys expire with the STS session (≤12h). Generate a long-term
# key in the Bedrock console for stable demos, or automate refresh.
AWS_BEARER_TOKEN_BEDROCK="bedrock-api-key-"

# Region of the inference profile. The token you create is tied to a region.
AWS_REGION=eu-north-1

# Inference-profile model ID. Example is EU Haiku 4.5 (matches the old Python
# agent). Swap to an EU Sonnet 4.6 ID for stronger tool use if available to
# your account.
BEDROCK_MODEL=eu.anthropic.claude-haiku-4-5-20251001-v1:0

# Max tokens per Bedrock turn.
BEDROCK_MAX_TOKENS=4096

# Safety cap on agent tool-call rounds per user turn.
AGENT_MAX_TOOL_ROUNDS=8

# MCP server reachable from Vercel's serverless runtime (must be public).
MCP_SERVER_URL=https://makeathon-2026-reply.fly.dev/mcp

# ─── ElevenLabs (browser-side, optional — enables voice mode) ────────────────
# If blank, the mic button is hidden. Bundled at build time → visible in JS,
# rotate after public demos.
VITE_ELEVENLABS_API_KEY=sk_ad2d29983e6998ebffcf4007e550951b9323c4cc665259b3
VITE_ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
VITE_ELEVENLABS_MODEL_ID=eleven_multilingual_v2
VITE_ELEVENLABS_STT_MODEL=scribe_v2



