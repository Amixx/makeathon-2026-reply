TUM_ENV=demo
FERNET_KEY=
GOOGLE_API_KEY=
TUM_USERNAME=
TUM_PASSWORD=

# Bedrock — set the bearer token for short-lived access, or rely on standard
# AWS creds (~/.aws/credentials, AWS_ACCESS_KEY_ID, etc.). boto3 picks whichever
# it finds. Region defaults to eu-north-1.
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=eu-north-1
BEDROCK_MODEL=eu.anthropic.claude-haiku-4-5-20251001-v1:0
