# ─── WayTum — all secrets in one place ────────────────────────────────────────
# Copy to .env (gitignored) and fill in values.
# For Fly.io production, set these as `fly secrets set KEY=VALUE`.

# ─── AI / LLM ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── Voice (ElevenLabs) ──────────────────────────────────────────────────────
ELEVENLABS_API_KEY=

# ─── TUM SSO (Playwright login) ──────────────────────────────────────────────
TUM_ENV=demo

# ─── MCP session encryption ─────────────────────────────────────────────────
FERNET_KEY=
